# ─── Pinata (IPFS) ────────────────────────────────────────────────────────────
# Get these from https://app.pinata.cloud/developers/api-keys
# PINATA_JWT is server-only (used in /api/pinata route — never expose to browser)
PINATA_JWT=your_pinata_jwt_here

# Your Pinata dedicated gateway subdomain (e.g. "myapp.mypinata.cloud")
# Leave empty to fall back to the public ipfs.io gateway
NEXT_PUBLIC_PINATA_GATEWAY=

# ─── TerraformaLand Contract ──────────────────────────────────────────────────
# After deploying to Monad Testnet, paste the deployed address here.
# Then also update packages/nextjs/contracts/deployedContracts.ts › 10143 › TerraformaLand › address
# Deploy command: yarn deploy --network monadTestnet (from repo root)
NEXT_PUBLIC_TERRAFORMA_LAND_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Wallet Connect ───────────────────────────────────────────────────────────
# Get a project ID at https://cloud.walletconnect.com
# Without this, WalletConnect QR modal will not work (MetaMask browser ext still works)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# ─── Alchemy (optional RPC override) ─────────────────────────────────────────
# If you want a dedicated Alchemy RPC instead of the public Monad testnet RPC
NEXT_PUBLIC_ALCHEMY_API_KEY=

# ─── Build flags ──────────────────────────────────────────────────────────────
# Set to "true" to skip TypeScript and ESLint errors during `yarn build`
NEXT_PUBLIC_IGNORE_BUILD_ERROR=false
